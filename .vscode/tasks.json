{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "restore: solution",
            "command": "powershell",
            "type": "process",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/solution.ps1",
                "restore"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build: solution",
            "command": "powershell",
            "type": "process",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/solution.ps1",
                "build"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean: solution",
            "command": "powershell",
            "type": "process",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/solution.ps1",
                "clean"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build: GameServer",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/GameServer/GameServer.csproj",
                "/property:GenerateFullPaths=true"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build: TestClient",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/CientTest/TestClient/TestClient.csproj",
                "/property:GenerateFullPaths=true"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build: Server + Client",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build: GameServer",
                "build: TestClient"
            ],
            "problemMatcher": []
        },
        {
            "label": "clean: GameServer",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}/GameServer/GameServer.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean: TestClient",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}/CientTest/TestClient/TestClient.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
